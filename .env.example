# ─── Database ──────────────────────────────────────────────
# Supabase PostgreSQL connection string (from Supabase dashboard > Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Supabase Auth ─────────────────────────────────────────
# From Supabase dashboard > Settings > API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret   # Settings > API > JWT Secret

# ─── Frontend (Vite VITE_ prefix required) ─────────────────
VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── AI (Gemini) ───────────────────────────────────────────
# From Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=AIza...

# ─── Local dev only (Replit) ───────────────────────────────
# SESSION_SECRET=...         (Replit handles this automatically)
# AI_INTEGRATIONS_GEMINI_API_KEY=...  (Replit Gemini integration)
# AI_INTEGRATIONS_GEMINI_BASE_URL=... (Replit Gemini integration)
